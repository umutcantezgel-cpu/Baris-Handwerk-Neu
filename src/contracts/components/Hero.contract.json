{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "Hero",
  "description": "High-impact landing section with background image, title, subtitle, and call-to-action buttons.",
  "props": {
    "title": {
      "type": "string",
      "required": true,
      "description": "Primary headline (H1)."
    },
    "subtitle": {
      "type": "string",
      "required": true,
      "description": "Supporting subheadline."
    },
    "backgroundImage": {
      "type": "string",
      "required": false,
      "description": "URL of the background image."
    },
    "primaryCtaText": {
      "type": "string",
      "default": "Angebot anfordern",
      "description": "Text for the primary button."
    },
    "secondaryCtaText": {
      "type": "string",
      "default": "Leistungen ansehen",
      "description": "Text for the secondary button."
    },
    "onPrimaryClick": {
      "type": "function",
      "required": false,
      "description": "Handler for primary CTA click."
    },
    "onSecondaryClick": {
      "type": "function",
      "required": false,
      "description": "Handler for secondary CTA click."
    }
  },
  "accessibility": {
    "role": "banner",
    "requirements": [
      "H1 must be unique on the page.",
      "Background image must have sufficient contrast with text (handled via scrim).",
      "Buttons must be focusable and have discernible text."
    ]
  },
  "tokens": {
    "title_font": "var(--font-family-display)",
    "spacing_bottom": "var(--spacing-8)"
  }
}